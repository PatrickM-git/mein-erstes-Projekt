      "id": "9597d3ad-280b-4ff8-8888-723c7d38d7d0",
      "name": "Google Sheets - Produkt_Aliase lesen",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        912,
        736
      ],
      "credentials": {
