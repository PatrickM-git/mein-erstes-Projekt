    {
      "parameters": {
        "jsCode": "const invoice = $items('Code - Claude JSON parsen')[0].json;\nconst products = $items('Google Sheets - Produkte lesen').map(i => i.json);\nconst batches = $items('Google Sheets - Lagerchargen lesen').map(i => i.json);\nconst aliases = $items('Google Sheets - Produkt_Aliase lesen').map(i => i.json);\n\nconst now = new Date().toISOString();\n\nfunction clean(v) {\n  return String(v ?? '').replace(/\\n/g, ' ').replace(/\\s+/g, ' ').trim();\n}\n\nfunction normalize(v) {\n  return clean(v)\n    .toLowerCase()\n    .replace(/&/g, 'und')\n    .replace(/\\+/g, 'plus')\n    .replace(/ä/g, 'ae')\n    .replace(/ö/g, 'oe')\n    .replace(/ü/g, 'ue')\n    .replace(/ß/g, 'ss')\n    .replace(/[^a-z0-9]/g, '');\n}\n\nfunction keyFromName(name) {\n  const base = clean(name)\n    .toUpperCase()\n    .replace(/Ä/g, 'AE')\n    .replace(/Ö/g, 'OE')\n    .replace(/Ü/g, 'UE')\n    .replace(/ẞ/g, 'SS')\n    .replace(/ß/g, 'SS')\n    .replace(/&/g, 'UND')\n    .replace(/\\+/g, 'PLUS')\n    .replace(/[^A-Z0-9]+/g, '_')\n    .replace(/^_+|_+$/g, '');\n  return `SKU_${base || 'UNBEKANNT'}`;\n}\n\nfunction batchId(productKey, purchaseDate, existingCount) {\n  const ymd = clean(purchaseDate).replace(/-/g, '') || new Date().toISOString().slice(0,10).replace(/-/g, '');\n  return `B_${String(productKey).replace(/^SKU_/, '')}_${ymd}_${existingCount + 1}`;\n}\n\nfunction nameMatches(a, b) {\n  const aa = normalize(a);\n  const bb = normalize(b);\n  if (!aa || !bb) return false;\n  if (aa === bb) return true;\n  if (aa.length >= 8 && bb.includes(aa)) return true;\n  if (bb.length >= 8 && aa.includes(bb)) return true;\n  return false;\n}\n\nfunction findProduct(line) {\n  const source = line.source_item;\n  const nayax = line.nayax_product_name;\n\n  const alias = aliases.find(a =>\n    nameMatches(a.alias_name, source) ||\n    nameMatches(a.alias_name, nayax) ||\n    nameMatches(a.source_item, source)\n  );\n\n  if (alias && clean(alias.product_key)) {\n    const product = products.find(p => clean(p.product_key) === clean(alias.product_key));\n    if (product) return { product, confidence: 'hoch', reason: 'Alias gefunden' };\n  }\n\n  const byName = products.find(p =>\n    nameMatches(p.nayax_product_name || p.internal_product_name, nayax) ||\n    nameMatches(p.internal_product_name || p.nayax_product_name, source)\n  );\n\n  if (byName) {\n    return { product: byName, confidence: 'mittel', reason: 'Namensähnlichkeit gefunden' };\n  }\n\n  return { product: null, confidence: 'prüfen', reason: 'Kein Produkt gefunden' };\n}\n\nconst suggestions = [];\nconst lines = invoice.invoice_lines || [];\n\nfor (const [index, line] of lines.entries()) {\n  const match = findProduct(line);\n  const isKnown = !!match.product;\n  const productKey = isKnown ? clean(match.product.product_key) : keyFromName(line.nayax_product_name || line.source_item);\n  const existingBatchCount = batches.filter(b => clean(b.product_key) === productKey).length;\n\n  const missing = [];\n  if (!clean(invoice.invoice_id)) missing.push('invoice_id');\n  if (!clean(invoice.supplier)) missing.push('supplier');\n  if (!clean(invoice.purchase_date)) missing.push('purchase_date');\n  if (!clean(line.source_item)) missing.push('source_item');\n  if (!Number.isFinite(Number(line.quantity)) || Number(line.quantity) <= 0) missing.push('quantity');\n  if (!clean(line.nayax_product_name)) missing.push('nayax_product_name');\n\n  const changeType = isKnown ? 'EXISTING_PRODUCT_NEW_BATCH' : 'NEW_PRODUCT_AND_BATCH';\n\n  suggestions.push({\n    created_at: now,\n    source_file_id: invoice.drive_file_id,\n    source_file_name: invoice.drive_file_name,\n    invoice_id: clean(invoice.invoice_id),\n    supplier: clean(invoice.supplier),\n    purchase_date: clean(invoice.purchase_date),\n    line_number: index + 1,\n    source_item: clean(line.source_item),\n    detected_quantity: Number(line.quantity ?? 0),\n    detected_mhd: clean(line.mhd),\n    detected_unit_cost: line.unit_cost ?? '',\n    mdb_code: clean(line.mdb_code),\n    approval_id: `APP_${invoice.drive_file_id}_${index + 1}`,\n    nayax_product_name: clean(line.nayax_product_name || line.source_item),\n    existing_product_key: isKnown ? productKey : '',\n    existing_product_name: isKnown ? (match.product.internal_product_name || match.product.nayax_product_name || '') : '',\n    suggested_product_key: productKey,\n    suggested_batch_id: batchId(productKey, invoice.purchase_date, existingBatchCount),\n    suggested_storage_location: $('Config - WF2').first().json.default_storage_location || 'Lager',\n    suggested_action: changeType,\n    confidence: missing.length ? 'unvollständig' : match.confidence,\n    needs_user_input: missing.length ? 'TRUE' : 'FALSE',\n    missing_fields: missing.join(', '),\n    approved: 'FALSE',\n    processed: 'FALSE',\n    notes: match.reason\n  });\n}\n\nif (!suggestions.length) {\n  throw new Error('Keine Rechnungspositionen erkannt. Datei wird nicht verschoben.');\n}\n\nreturn suggestions.map(s => ({ json: s }));",
        "mode": "runOnceForAllItems"
      },
