    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\n\nif (!buffer) {\n  throw new Error('Keine Binärdaten im Feld data gefunden.');\n}\n\nconst file = item.binary.data;\n\nreturn [\n  {\n    json: {\n      file_base64: buffer.toString('base64'),\n      mime_type: file.mimeType || 'application/pdf',\n      file_name: file.fileName || 'rechnung.pdf',\n      drive_file_id: item.json.id,\n      drive_file_name: item.json.name\n    }\n  }\n];",
        "mode": "runOnceForAllItems"
      },
      "id": "e266a351-976c-4245-a1f8-10f953fa7644",
      "name": "Code - Claude Input vorbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        384
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 4000,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"document\",\n          \"source\": {\n            \"type\": \"base64\",\n            \"media_type\": \"application/pdf\",\n            \"data\": \"{{ $json.file_base64 }}\"\n          }\n        },\n        {\n          \"type\": \"text\",\n          \"text\": \"Du bist ein Rechnungsparser für ein Automatenlager. Extrahiere aus der Rechnung ausschließlich valides JSON. Keine Markdown-Codeblöcke, keine Erklärung.\\n\\nSchema:\\n{\\\"invoice_id\\\":\\\"\\\",\\\"supplier\\\":\\\"\\\",\\\"purchase_date\\\":\\\"YYYY-MM-DD\\\",\\\"invoice_lines\\\":[{\\\"source_item\\\":\\\"\\\",\\\"quantity\\\":0,\\\"mhd\\\":\\\"YYYY-MM-DD oder leer\\\",\\\"unit_cost\\\":0,\\\"nayax_product_name\\\":\\\"\\\",\\\"mdb_code\\\":\\\"\\\",\\\"sale_price_eur\\\":\\\"\\\"}]}\\n\\nRegeln:\\npurchase_date ist das Rechnungsdatum oder Lieferdatum, wenn kein Rechnungsdatum erkennbar ist.\\n\\nquantity ist die Anzahl der gekauften verkaufbaren Einheiten bzw. Verkaufspackungen, nicht die Anzahl einzelner Stücke innerhalb einer Packung.\\n\\nWenn eine Positionsbezeichnung mehrere Zahlen mit \\\"x\\\" enthält, dann ist die erste Zahl vor dem ersten \\\"x\\\" die quantity.\\n\\nBeispiele:\\n\\\"30x2x21,5g KINDER BU KLASSIK\\\" bedeutet quantity = 30, weil 30 Doppelpackungen gekauft wurden.\\n\\\"24x36g M&M CRISPY EINZELBEUTEL\\\" bedeutet quantity = 24.\\n\\\"12x0,5L GETRÄNK\\\" bedeutet quantity = 12.\\n\\nunit_cost ist der Netto- oder Brutto-Einzelpreis pro verkaufbarer Einheit, wenn eindeutig erkennbar, sonst leer.\\n\\nMHD nur übernehmen, wenn es auf der Rechnung steht.\\n\\nnayax_product_name zunächst aus source_item ableiten.\\n\\nmdb_code und sale_price_eur leer lassen, wenn nicht auf der Rechnung vorhanden.\\n\\nWenn eine Position unklar ist, trotzdem aufnehmen und fehlende Werte leer lassen.\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "id": "9de0623f-2a95-436b-862e-b344562aa1b3",
      "name": "Claude - Rechnung auslesen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1296,
        384
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "MYA5fchuUNDDWJ4Z",
          "name": "Claude API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.content?.[0]?.text;\n\nif (!raw) {\n  throw new Error('Claude Antwort enthält keinen Text.');\n}\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  throw new Error('Claude hat kein valides JSON geliefert: ' + raw.slice(0, 300));\n}\n\nreturn [\n  {\n    json: {\n      ...parsed,\n      drive_file_id: $('Code - Claude Input vorbereiten').first().json.drive_file_id,\n      drive_file_name: $('Code - Claude Input vorbereiten').first().json.drive_file_name\n    }\n  }\n];",
        "mode": "runOnceForAllItems"
      },
